# =============================================================
# Backend Environment Configuration
# Copy this file to `.env` and adjust values for your environment.
# NEVER commit a real `.env` file with production secrets.
# =============================================================

# --- Runtime ---
# One of: development | test | production
NODE_ENV=development
PORT=3000

# --- CORS ---
# Comma-separated list of allowed origins for CORS.
# Only these origins can make cross-origin requests.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Auth ---
# JWT secret for signing tokens. MUST be a long random string in production.
# WARNING: Do NOT use default values in production!
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=24h

# --- Crypto Zone ---
# Shared secret required by callers of /api/internal/crypto/* endpoints
# and used to derive the encryption key for the Falcon private key store.
# MUST be rotated and replaced before going to production.
# WARNING: Do NOT use default values in production!
INTERNAL_CRYPTO_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Backing store for Falcon-512 keys. Supported values:
#   file           - encrypted JSON keystore on local disk (development default)
#   hsm            - hardware security module (production)
#   azure-keyvault - Azure Key Vault (production)
#   aws-kms        - AWS KMS (production)
KEY_STORAGE_TYPE=file

# --- Public verification ---
# Base URL embedded into QR codes so citizens can verify a signed document.
# Must be reachable from the public internet in production.
PUBLIC_VERIFY_URL=http://localhost:3000/api/public/documents/verify

# --- Database ---
# Chọn 'json' để dùng file, hoặc 'mysql' để dùng database
DB_STORAGE_TYPE=json

# MySQL configuration (only needed when DB_STORAGE_TYPE=mysql)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=document_verification
DB_PORT=3306

# Audit log table name (must be a valid identifier)
AUDIT_TABLE=audit_logs
