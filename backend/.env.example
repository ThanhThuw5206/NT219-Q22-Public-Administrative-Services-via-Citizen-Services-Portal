# Example environment configuration for the backend service.
# Copy this file to `.env` and adjust values for your environment.
# Never commit a real `.env` file with production secrets.

# --- Crypto Zone ---
# Shared secret required by callers of /api/internal/crypto/* endpoints
# and used to derive the encryption key for the Falcon private key store.
# MUST be rotated and replaced before going to production.
INTERNAL_CRYPTO_SECRET=change-me-in-production

# Backing store for Falcon-512 keys. Supported values:
#   file           - encrypted JSON keystore on local disk (development default)
#   hsm            - hardware security module (production)
#   azure-keyvault - Azure Key Vault (production)
#   aws-kms        - AWS KMS (production)
KEY_STORAGE_TYPE=file

# --- Signing Mode ---
# Determines how officer signatures are created:
#   hsm    (default) - Server acts as HSM: holds officer keys in encrypted keystore,
#                      signs on officer's behalf after JWT authentication.
#                      Identity binding: JWT + audit trail.
#                      Officers do NOT need a device key.
#
#   device           - Officer holds Falcon-512 private key on their device (browser).
#                      Server only stores public key. Officer signs challenges
#                      client-side and sends proof to server.
#                      Strongest identity proof — private key never leaves device.
SIGNING_MODE=hsm

# Legacy flags (derived from SIGNING_MODE, override only if needed):
# ALLOW_SERVER_SIDE_PERSONAL_KEYS: auto-set to true in hsm mode
# REQUIRE_OFFICER_DEVICE_SIGNATURE: auto-set to true in device mode
# ALLOW_SERVER_SIDE_PERSONAL_KEYS=false
# REQUIRE_OFFICER_DEVICE_SIGNATURE=true
ALLOW_FILE_ORGANIZATION_SEAL_IN_PRODUCTION=false

# --- Public verification ---
# Base URL embedded into QR codes so citizens can verify a signed document.
# Must be reachable from the public internet in production.
PUBLIC_VERIFY_URL=http://localhost:3000/api/public/documents/verify

# --- Runtime ---
# One of: development | test | production
NODE_ENV=development
PORT=3000

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h

# --- Optional MySQL schema experiments ---
# The current demo flow uses JSON file storage. These values are only needed
# if you wire repositories to DB/db.sql.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=document_verification
DB_PORT=3307

# Chọn 'json' để dùng file của bạn kia, hoặc 'mysql' để dùng database của bạn
DB_STORAGE_TYPE=mysql
